# NeuroStride — Environment Variable Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (local/demo):
DATABASE_URL=sqlite:///./neurostride.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/neurostride

# ── Application ───────────────────────────────────────────────────────────────
ENV=development   # Set to "production" to disable /docs and /redoc

# ── Auth / Security ───────────────────────────────────────────────────────────
# Generate a strong random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-in-production

# Comma-separated list of allowed frontend origins (no wildcard in production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── AI — Groq ─────────────────────────────────────────────────────────────────
# Get your key from https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# ── Observability — Langfuse ──────────────────────────────────────────────────
# Get your keys from https://cloud.langfuse.com/
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Hardware (local only) ─────────────────────────────────────────────────────
NEUPHONY_PORT=COM3
SERVO_PORT=COM4
