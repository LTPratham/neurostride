# NeuroStride — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local / demo)
DATABASE_URL=sqlite:///./neurostride.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://neurostride:<password>@<host>:5432/neurostride

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-in-production

# ── AI — Groq ─────────────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ── Observability — Langfuse ──────────────────────────────────────────────────
# Get keys at: https://cloud.langfuse.com (free tier available)
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Hardware — Neuphony EXG Synapse ───────────────────────────────────────────
# Check Device Manager → Ports for your board's COM port
NEUPHONY_PORT=COM3
SERVO_PORT=COM4
